---
import ProyectItem from "../Items/ProyectItem.astro"
const Proyectos = [
  {
    Name: "AVR Make Action",
    Type: "Vscode Extension",
    Tools: ["Typescript", "C"],
    Description: "Extensión para VSCode que automatiza la compilación y gestión de proyectos AVR. Permite ejecutar acciones personalizadas, integración con Makefiles y facilita el flujo de trabajo para desarrolladores embebidos.",
    GitLink: "",
    PrevLink: "wefwe",
  },
  {
    Name: "AVR Register Configurator",
    Type: "Vscode Extension",
    Tools: ["Typescript", "C"],
    Description: "Herramienta interactiva para configurar registros de microcontroladores AVR directamente desde VSCode. Ofrece visualización, edición y generación automática de código para inicialización de periféricos.",
    GitLink: "",
    PrevLink: "fwefwef",
  },
  {
    Name: "Virtual Keyboard Extension for Firefox",
    Type: "Firefox Extension",
    Tools: ["Javascript", "Firefox"],
    Description: "Linux Virtual Keyboard Emulator integrated into Firefox. Provides an on-screen keyboard for enhanced accessibility and user convenience while browsing.",
    PrevLink: "https://addons.mozilla.org/es-MX/firefox/addon/virtualkey/",
  },
  {
    Name: "CloudFlare Infrastructure for OTA with workers",
    Type: "CloudFlare & Hardware Project",
    Tools: ["Terraform", "Cloudflare", "CloudflareWorkers", "Javascript", "C","Espressif","ST"],
    Description: "Infrastructure setup for Over-the-Air updates using CloudFlare workers. Ensures seamless and secure deployment of updates to devices.",
  },
  {
    Name: "Raspberry Pi Remote CNC Controller",
    Type: "Hardware & Software Project",
    Tools: ["Java", "SpringBoot", "RaspberryPI"],
    Description: "A remote CNC controller built on Raspberry Pi, allowing users to manage and operate CNC machines from a web interface. Utilizes Java and Spring Boot for backend services, providing real-time control and monitoring capabilities.",
  },
  {
    Name: "FingerPrint Authentication with ESP32",
    Type: "Hardware Project",
    Tools: ["C", "Espressif", "Cloudflare",],
    Description: "A biometric authentication system using ESP32 and a fingerprint sensor. Integrates with Cloudflare for secure data handling and remote access, providing a robust solution for access control applications.",

  },
]
---

<!-- Projects Grid Container -->
<section class="w-full px-4 sm:px-6 lg:px-8 mt-16 mx-auto max-w-7xl">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
    {
      Proyectos.map((project, index) => (
        <div class="project-card-wrapper h-full" style={`--index: ${index};`}>
            <ProyectItem {...project} />
        </div>
      ))
    }
  </div>
</section>

<style>
  .project-card-wrapper {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    animation-delay: calc(var(--index) * 0.1s);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduce motion preference */
  @media (prefers-reduced-motion: reduce) {
    .project-card-wrapper {
      animation: none;
      opacity: 1;
    }
  }
</style>