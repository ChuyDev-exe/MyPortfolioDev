---
export const prerender = false;
import Logo_m from "../components/Global/Logo_m.astro";
import LayoutLink from "../layouts/LayoutLink.astro";
---

<LayoutLink
    title="Jesus Velez | Linktree"
    description="Todos los enlaces importantes de Jesus Velez - Full-Stack & Embedded Developer"
    keywords="Jesus Velez, Jesus Velez Soto, enlaces, links, linktree"
    author="Jesus Velez Soto"
>
    <!-- Animated background orbs -->
    <div
        class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
        aria-hidden="true"
    >
        <div
            class="orb orb-1 absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-[#51E4B8]/5 blur-[140px]"
        >
        </div>
        <div
            class="orb orb-2 absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[#21554E]/8 blur-[120px]"
        >
        </div>
        <div
            class="orb orb-3 absolute top-[40%] left-[50%] w-[30%] h-[30%] rounded-full bg-[#51E4B8]/3 blur-[100px]"
        >
        </div>
        <div
            class="orb orb-4 absolute top-[60%] left-[10%] w-[25%] h-[25%] rounded-full bg-[#51E4B8]/4 blur-[80px]"
        >
        </div>
    </div>

    <div
        class="flex flex-col items-center w-full max-w-sm md:max-w-md mx-auto px-5 sm:px-6 pt-1 sm:pt-12 pb-8 gap-3 sm:gap-4 animate-fade-in"
    >
        <!-- Logo -->
        <div class="w-full flex justify-center -mt-[13vh] mb-3 sm:-mt-0">
            <Logo_m />
        </div>

        <!-- Tagline -->
        <p
            class="text-base sm:text-lg text-center -mt-6 sm:-mt-8 mb-1 tracking-wide font-semibold text-white/80 drop-shadow-[0_0_12px_rgba(81,228,184,0.2)]"
        >
            Full-Stack & Embedded Developer
        </p>

        <!-- Servicios -->
        <details
            class="group overflow-hidden rounded-2xl border border-[#51E4B8]/25 bg-white/[0.02] backdrop-blur-sm transition-all duration-300 open:border-[#51E4B8]/50 open:shadow-[0_0_35px_rgba(81,228,184,0.12)]"
        >
            <summary
                class="flex cursor-pointer items-center gap-4 px-5 py-4 list-none [&::-webkit-details-marker]:hidden transition-colors duration-300 hover:bg-[#51E4B8]/5"
            >
                <div
                    class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#51E4B8]/10 border border-[#51E4B8]/20 text-[#51E4B8]"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.7"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"
                        ></path>
                    </svg>
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-white">Servicios Web</h3>
                    <p class="text-xs text-gray-400 mt-0.5">
                        Soluciones digitales, embebidas y automatización.
                    </p>
                </div>
                <div
                    class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/5 border border-white/10 transition-all duration-300 group-open:rotate-180 group-open:bg-[#51E4B8]/10 group-open:border-[#51E4B8]/30"
                >
                    <svg
                        class="w-4 h-4 text-[#51E4B8]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                    </svg>
                </div>
            </summary>
            <div
                class="flex flex-col gap-2 px-5 pb-4 pt-4 sm:grid-cols-2 lg:grid-cols-3"
            >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Tarjetas de Lealtad</span
                >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Desarrollo Web Personalizadas</span
                >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Agendas Digitales Personalizadas</span
                >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Menus Digitales con QR</span
                >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Registro de Eventos</span
                >
            </div>
        </details>

        <details
            class="group overflow-hidden rounded-2xl border border-[#51E4B8]/25 bg-white/[0.02] backdrop-blur-sm transition-all duration-300 open:border-[#51E4B8]/50 open:shadow-[0_0_35px_rgba(81,228,184,0.12)]"
        >
            <summary
                class="flex cursor-pointer items-center gap-4 px-5 py-4 list-none [&::-webkit-details-marker]:hidden transition-colors duration-300 hover:bg-[#51E4B8]/5"
            >
                <div
                    class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#51E4B8]/10 border border-[#51E4B8]/20 text-[#51E4B8]"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.7"
                    >
                        <rect
                            x="6"
                            y="6"
                            width="12"
                            height="12"
                            rx="1.5"
                            stroke-width="1.5"
                            stroke="currentColor"
                            fill="none"></rect>
                        <path
                            stroke-linecap="round"
                            stroke-width="1.5"
                            stroke="currentColor"
                            fill="none"
                            d="M6 9H3m18 0h-3M6 12H2m20 0h-2M6 15H3m18 0h-3M9 6V3m6 3V3M9 21v-3m6 3v-3"
                        ></path>
                        <rect
                            x="9.5"
                            y="9.5"
                            width="5"
                            height="5"
                            rx="0.5"
                            stroke-width="1"
                            stroke="currentColor"
                            fill="none"></rect>
                    </svg>
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-white">
                        Dispositivos Electronicos
                    </h3>
                    <p class="text-xs text-gray-400 mt-0.5">
                        Soluciones digitales, embebidas y automatización.
                    </p>
                </div>
                <div
                    class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/5 border border-white/10 transition-all duration-300 group-open:rotate-180 group-open:bg-[#51E4B8]/10 group-open:border-[#51E4B8]/30"
                >
                    <svg
                        class="w-4 h-4 text-[#51E4B8]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                    </svg>
                </div>
            </summary>
            <div
                class="flex flex-col gap-2 px-5 pb-4 pt-4 sm:grid-cols-2 lg:grid-cols-3"
            >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Control de Inventarios con Bots</span
                >
                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Portal de Conexion a Internet</span
                >

                <span
                    class="rounded-xl border border-[#51E4B8]/20 bg-[#51E4B8]/8 px-3 py-2 text-xs font-medium text-[#51E4B8] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#51E4B8]/50 hover:bg-[#51E4B8]/15"
                    >Kioskos Touch Multiservicio</span
                >
            </div>
        </details>

        <!-- Gradient divider -->
        <div
            class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent my-0.5"
        >
        </div>

        <!-- Links -->
        <div class="w-full grid grid-cols-2 sm:grid-cols-3 gap-3 md:gap-4">
            <a
                href="https://jesusvelez.xyz"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visitar mi Portfolio"
                class="group flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/20 bg-transparent text-gray-400 text-xs sm:text-sm font-medium transition-all duration-300 hover:bg-[#51E4B8]/25 hover:border-[#51E4B8]/50 hover:text-[#51E4B8] hover:shadow-[0_0_25px_-3px_rgba(81,228,184,0.4)] hover:-translate-y-1 active:scale-95"
            >
                <svg
                    class="w-4 h-4 shrink-0 transition-all duration-300 group-hover:scale-125"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
                    ></path></svg
                >
                Portfolio
            </a>
            <a
                href="https://github.com/ChuyDev-exe"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visitar mi perfil de GitHub"
                class="group flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/20 bg-transparent text-gray-400 text-xs sm:text-sm font-medium transition-all duration-300 hover:bg-[#51E4B8]/25 hover:border-[#51E4B8]/50 hover:text-[#51E4B8] hover:shadow-[0_0_25px_-3px_rgba(81,228,184,0.4)] hover:-translate-y-1 active:scale-95"
            >
                <svg
                    class="w-4 h-4 shrink-0 transition-all duration-300 group-hover:scale-125"
                    viewBox="0 0 1024 1024"
                    fill="none"
                    ><path
                        fill-rule="evenodd"
                        clip-rule="evenodd"
                        d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
                        transform="scale(64)"
                        fill="#ffff"></path></svg
                >
                GitHub
            </a>
            <a
                href="https://www.linkedin.com/in/jesus-velez-soto-28ab11156/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Conectar en LinkedIn"
                class="group flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/20 bg-transparent text-gray-400 text-xs sm:text-sm font-medium transition-all duration-300 hover:bg-[#51E4B8]/25 hover:border-[#51E4B8]/50 hover:text-[#51E4B8] hover:shadow-[0_0_25px_-3px_rgba(81,228,184,0.4)] hover:-translate-y-1 active:scale-95"
            >
                <svg
                    class="w-4 h-4 shrink-0 transition-all duration-300 group-hover:scale-125"
                    preserveAspectRatio="xMidYMid"
                    viewBox="0 0 256 256"
                    ><path
                        d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"
                        fill="#0A66C2"></path></svg
                >
                LinkedIn
            </a>
            <a
                href="/DevBlog"
                aria-label="Leer mi Blog"
                class="group flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/20 bg-transparent text-gray-400 text-xs sm:text-sm font-medium transition-all duration-300 hover:bg-[#51E4B8]/25 hover:border-[#51E4B8]/50 hover:text-[#51E4B8] hover:shadow-[0_0_25px_-3px_rgba(81,228,184,0.4)] hover:-translate-y-1 active:scale-95"
            >
                <svg
                    class="w-4 h-4 shrink-0 transition-all duration-300 group-hover:scale-125"
                    viewBox="0 0 32 32"
                    fill="none"
                    aria-labelledby="tanukiHomeDesktop"
                    ><path
                        d="m31.46 12.78-.04-.12-4.35-11.35A1.14 1.14 0 0 0 25.94.6c-.24 0-.47.1-.66.24-.19.15-.33.36-.39.6l-2.94 9h-11.9l-2.94-9A1.14 1.14 0 0 0 6.07.58a1.15 1.15 0 0 0-1.14.72L.58 12.68l-.05.11a8.1 8.1 0 0 0 2.68 9.34l.02.01.04.03 6.63 4.97 3.28 2.48 2 1.52a1.35 1.35 0 0 0 1.62 0l2-1.52 3.28-2.48 6.67-5h.02a8.09 8.09 0 0 0 2.7-9.36Z"
                        fill="#E24329"></path><path
                        d="m31.46 12.78-.04-.12a14.75 14.75 0 0 0-5.86 2.64l-9.55 7.24 6.09 4.6 6.67-5h.02a8.09 8.09 0 0 0 2.67-9.36Z"
                        fill="#FC6D26"></path><path
                        d="m9.9 27.14 3.28 2.48 2 1.52a1.35 1.35 0 0 0 1.62 0l2-1.52 3.28-2.48-6.1-4.6-6.07 4.6Z"
                        fill="#FCA326"></path><path
                        d="M6.44 15.3a14.71 14.71 0 0 0-5.86-2.63l-.05.12a8.1 8.1 0 0 0 2.68 9.34l.02.01.04.03 6.63 4.97 6.1-4.6-9.56-7.24Z"
                        fill="#FC6D26"></path></svg
                >
                Gitlab
            </a>
            <a
                href="mailto:jesus@jesusvelez.xyz"
                aria-label="Enviarme un correo electrónico"
                class="group flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/20 bg-transparent text-gray-400 text-xs sm:text-sm font-medium transition-all duration-300 hover:bg-[#51E4B8]/25 hover:border-[#51E4B8]/50 hover:text-[#51E4B8] hover:shadow-[0_0_25px_-3px_rgba(81,228,184,0.4)] hover:-translate-y-1 active:scale-95"
            >
                <svg
                    class="w-4 h-4 shrink-0 transition-all duration-300 group-hover:scale-125"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                    ></path></svg
                >
                Email
            </a>
        </div>
    </div>
</LayoutLink>

<style>
    .orb {
        animation: floatOrb 20s ease-in-out infinite;
    }
    .orb-1 {
        animation-duration: 25s;
        animation-delay: -2s;
    }
    .orb-2 {
        animation-duration: 20s;
        animation-delay: -5s;
    }
    .orb-3 {
        animation-duration: 30s;
        animation-delay: -10s;
    }
    .orb-4 {
        animation-duration: 22s;
        animation-delay: -7s;
    }

    @keyframes floatOrb {
        0%,
        100% {
            transform: translate(0, 0) scale(1);
        }
        25% {
            transform: translate(30px, -40px) scale(1.1);
        }
        50% {
            transform: translate(-20px, 20px) scale(0.95);
        }
        75% {
            transform: translate(40px, 30px) scale(1.05);
        }
    }
</style>
