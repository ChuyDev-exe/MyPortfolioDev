---
export const prerender = false;
import Logo from "../components/Global/Logo.astro";
import NavItem from "../components/NavItem.astro";
import Layout from "../layouts/Layout.astro";
import Experience from "../components/Containers/Experience.astro";
import Proyects from "../components/Containers/Proyects.astro";
import TabsComponent from "../components/Items/Skill";

const subdomain = Astro.locals.subdomain?.toLowerCase() || '';
---

<Layout
	title="Jesus Velez | Desarrollador Full-Stack | jesusvelez.xyz"
	description="Jesus Velez - Desarrollador Full-Stack especializado en React, Next.js, Node.js y sistemas embebidos. Portfolio oficial de Jesus Velez Soto con proyectos innovadores en desarrollo web y microcontroladores."
	keywords="Jesus Velez, Jesus Velez Soto, jesusvelez.xyz, desarrollador full-stack, programador, React, Next.js, Node.js, sistemas embebidos, microcontroladores, ESP32, portfolio Jesus Velez, desarrollador web Jesus Velez"
	author="Jesus Velez Soto"
>
	{subdomain === '' && (
		<>
			<nav
				id="navbar"
				class="hidden sm:flex flex-row gap-4 justify-center items-center mt-24 mb-16 z-50 transition-all duration-300 bg-transparent sticky top-10 backdrop-blur-sm border border-white rounded-full py-2 px-10 w-fit mx-auto"
				aria-label="Navegación principal"
			>
				<NavItem title="About" href="/about" />
				<NavItem title="Experience" href="#Experiencia" />
				<NavItem title="Projects" href="#Projects" />
				<NavItem title="Blog" href="/DevBlog" />
			</nav>

			<!-- Mobile Navigation Button -->
			<button id="mobile-menu-btn" class="fixed top-4 left-4 z-50 p-2 rounded-full bg-black/50 backdrop-blur-md border border-white/20 text-white sm:hidden hover:bg-white/10 transition-colors" aria-label="Abrir menú">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
				  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
				</svg>
			</button>

			<!-- Mobile Navigation Overlay -->
			<div id="mobile-menu" class="fixed inset-0 z-[60] bg-black/95 backdrop-blur-xl transform -translate-x-full transition-transform duration-700 flex flex-col items-center justify-center sm:hidden overflow-hidden">
				<!-- Background Animation -->
				<div class="absolute inset-0 z-[-1] opacity-30 pointer-events-none">
					<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-[#51E4B8] blur-[120px] animate-pulse"></div>
					<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[#21554E] blur-[120px] animate-pulse delay-700"></div>
				</div>

				<button id="close-menu-btn" class="absolute top-6 right-6 p-2 text-white hover:text-[#51E4B8] transition-colors" aria-label="Cerrar menú">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
					  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
				<nav class="flex flex-col gap-8 text-center relative z-10">
					<NavItem title="About" href="/about" class="text-3xl" />
					<NavItem title="Experience" href="#Experiencia" class="text-3xl" />
					<NavItem title="Projects" href="#Projects" class="text-3xl" />
					<NavItem title="Blog" href="/DevBlog" class="text-3xl" />
				</nav>
			</div>

			<!-- Ambient background orbs -->
			<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
				<div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-[#51E4B8]/5 blur-[140px]"></div>
				<div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[#21554E]/8 blur-[120px]"></div>
				<div class="absolute top-[40%] left-[50%] w-[30%] h-[30%] rounded-full bg-[#51E4B8]/3 blur-[100px]"></div>
			</div>

			<Logo />

			<!-- Badge "Open to Work" -->
			<div class="flex items-center w-full justify-center mb-10">
				<span class="relative inline-flex overflow-hidden rounded-full p-px">
					<span class="absolute inset-[-1000%] animate-[spin_2s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#51E4B8_0%,#21554E_50%,#51E4B8_100%)]" />
					<a
						href="https://www.linkedin.com/in/jesus-velez-soto-28ab11156/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center gap-2 w-full px-4 py-1.5 text-sm font-medium text-[#51E4B8] bg-[#050d15] rounded-full cursor-pointer backdrop-blur-3xl whitespace-nowrap hover:bg-[#0a1f18] transition-colors"
					>
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#51E4B8] opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-[#51E4B8]"></span>
						</span>
						Open to Work
					</a>
				</span>
			</div>

			<!-- Hero text -->
			<section class="flex flex-col items-center w-full justify-center mb-[100px] px-4 gap-8">
				<div class="text-center max-w-2xl">
					<p class="text-4xl max-sm:text-2xl font-semibold text-white leading-tight tracking-tight">
						<span class="block text-[#51E4B8]">Full-Stack & Embedded Engineer</span>
					</p>
					<p class="text-base md:text-lg text-gray-400 mt-2 leading-relaxed">
						3+ años construyendo aplicaciones web modernas y dispositivos embebidos con Linux.
						<span class="text-gray-300"> Freelance · 🇲🇽 México</span>
					</p>
				</div>

				<!-- CTA buttons -->
				<div class="flex flex-wrap gap-4 justify-center mt-2">
					<a
						href="#Projects"
						class="inline-flex items-center gap-2 px-6 py-3 bg-[#51E4B8] hover:bg-[#45d4a8] text-[#050d15] font-semibold rounded-xl transition-all duration-300 hover:shadow-[0_0_30px_-5px_rgba(81,228,184,0.5)] hover:-translate-y-0.5"
					>
						Ver Proyectos
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
						</svg>
					</a>
					<a
						href="mailto:jesus@jesusvelez.xyz"
						class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 hover:border-[#51E4B8]/50 text-white font-medium rounded-xl transition-all duration-300 hover:bg-white/5 hover:-translate-y-0.5"
					>
						Contacto
					</a>
				</div>
			</section>

			<div
				class="w-full flex items-center justify-center flex-col mt-[100px]"
				id="Experiencia"
			>
				<h1 class="max-sm:text-2xl text-5xl font-semibold text-white my-5">
					Experiencia
				</h1>
				<Experience />
			</div>

			<div
				class="w-full flex items-center justify-center flex-col mt-[200px]"
				id="Skills"
			>
				<h1 class="max-sm:text-2xl text-5xl font-semibold text-white my-5">
					Skills
				</h1>
				<TabsComponent client:load/>
			</div>

			<div
				class="w-full flex items-center justify-center flex-col mt-[200px]"
				id="Projects"
			>
				<h1 class="max-sm:text-2xl text-5xl font-semibold text-white my-5">
					Proyectos
				</h1>
				<Proyects />
			</div>
		</>
	)}
</Layout>

<script>
window.addEventListener("scroll", () => {
  const nav = document.getElementById("navbar");

  if (nav) {
    if (window.scrollY > 90) {
      nav.classList.remove("mt-24");
      nav.classList.add(
        "border",
        "rounded-full",
        "border-white",
        "mt-10",
        "sticky",
        "top-10",
        "py-2",
        "px-10",
        "backdrop-blur-sm",
        "w-fit"
      );
    } else {
      nav.classList.add("mt-24");
      nav.classList.remove(
        "border",
        "backdrop-blur-sm",
        "rounded-full",
        "border-white",
        "sticky",
        "top-10",
        "py-2",
        "px-10",
        "mt-10",
        "w-fit"
      );
    }
  }
});

// Mobile Menu Logic
const mobileMenuBtn = document.getElementById("mobile-menu-btn");
const closeMenuBtn = document.getElementById("close-menu-btn");
const mobileMenu = document.getElementById("mobile-menu");
const mobileLinks = mobileMenu?.querySelectorAll("a");

function toggleMenu() {
  mobileMenu?.classList.toggle("-translate-x-full");
  document.body.classList.toggle("overflow-hidden");
}

mobileMenuBtn?.addEventListener("click", toggleMenu);
closeMenuBtn?.addEventListener("click", toggleMenu);

mobileLinks?.forEach(link => {
  link.addEventListener("click", toggleMenu);
});
</script>
