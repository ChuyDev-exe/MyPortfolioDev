---
interface Props {
	title: string;
	description?: string;
	image?: string;
	keywords?: string;
	author?: string;
	url?: string;
}

const currentYear = new Date().getFullYear();
const {
	title,
	description = "Jesus Velez - Full-Stack Developer especializado en desarrollo web moderno, microcontroladores y sistemas embebidos. Sitio oficial de Jesus Velez Soto (jesusvelez.xyz) con portfolio y proyectos en React, Next.js, Node.js, ESP32 y más.",
	image = "/og-image.jpg",
	keywords = "Jesus Velez, Jesus Velez Soto, jesusvelez.xyz, desarrollador full-stack, programador web, microcontroladores, sistemas embebidos, React, Next.js, Node.js, ESP32, JavaScript, TypeScript, portfolio Jesus Velez",
	author = "Jesus Velez Soto",
	url = Astro.url.href
} = Astro.props;
import "../styles/global.css";
import "@fontsource-variable/onest";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content={author} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="index, follow" />
		<meta name="language" content="es" />
		<meta name="theme-color" content="#51E4B8" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url).href} />
		<meta property="og:site_name" content="Jesus Velez Soto - Portfolio" />
		<meta property="og:locale" content="es_ES" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url).href} />
		<meta name="twitter:creator" content="@ChuyDev" />

		<!-- Canonical URL -->
		<link rel="canonical" href={url} />

		<!-- Favicons -->
		<link rel="icon" type="image/x-icon" href="/Logo.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Generator -->
		<meta name="generator" content={Astro.generator} />

		<!-- Preload critical fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Allan&family=IM+Fell+Great+Primer+SC&family=Imperial+Script&family=Imprima&display=swap"
			media="print"
			onload="this.media='all'"
		/>

		<!-- JSON-LD Schema Markup -->
		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Jesus Velez Soto",
			"alternateName": "Jesus Velez",
			"jobTitle": "Full-Stack Developer",
			"description": "Jesus Velez - Desarrollador Full-Stack especializado en tecnologías web modernas y sistemas embebidos. Creador de soluciones innovadoras en React, Node.js y microcontroladores.",
			"url": "https://jesusvelez.xyz",
			"mainEntityOfPage": "https://jesusvelez.xyz",
			"image": "https://jesusvelez.xyz/og-image.jpg",
			"sameAs": [
				"https://github.com/ChuyDev-exe",
				"https://www.linkedin.com/in/jesus-velez-soto-28ab11156/",
				"https://codepen.io/chuydev-exe"
			],
			"knowsAbout": [
				"JavaScript",
				"TypeScript",
				"React",
				"Next.js",
				"Node.js",
				"Angular",
				"Desarrollo Web",
				"Full-Stack Development",
				"Sistemas Embebidos",
				"ESP32",
				"Microcontroladores",
				"Backend Development",
				"Frontend Development",
				"Web Development"
			],
			"workLocation": {
				"@type": "Place",
				"name": "Remote"
			},
			"hasOccupation": {
				"@type": "Occupation",
				"name": "Full-Stack Developer",
				"occupationLocation": {
					"@type": "Place",
					"name": "Worldwide"
				}
			}
		}
		</script>
	</head>
	<body>
		<div class="flex flex-col w-full justify-center items-center">
			<slot />
		</div>

		<footer class="w-full mt-20 text-slate-50">
			<!-- Gradient divider -->
			<div class="h-px w-full bg-gradient-to-r from-transparent via-[#51E4B8]/40 to-transparent"></div>

			<div class="max-w-5xl mx-auto px-6 py-16 flex flex-col items-center gap-10">
				<!-- Name & tagline -->
				<div class="text-center">
					<p class="text-xs uppercase tracking-[0.2em] text-gray-500 mb-2">Designed & Developed by</p>
					<h2 class="text-2xl md:text-4xl font-semibold tracking-tight">
						Jesus Velez Soto
					</h2>
					<p class="text-sm text-gray-500 mt-1">Full-Stack & Embedded Developer · {currentYear}</p>
				</div>

				<!-- Links -->
				<nav class="flex flex-wrap justify-center gap-8 md:gap-10" aria-label="Footer links">
					<a
						href="mailto:jesus@jesusvelez.xyz"
						class="text-sm font-medium text-gray-400 hover:text-[#51E4B8] transition-colors duration-300 tracking-wide"
					>
						Email
					</a>
					<a
						href="https://github.com/ChuyDev-exe"
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm font-medium text-gray-400 hover:text-[#51E4B8] transition-colors duration-300 tracking-wide"
					>
						GitHub
					</a>
					<a
						href="https://www.linkedin.com/in/jesus-velez-soto-28ab11156/"
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm font-medium text-gray-400 hover:text-[#51E4B8] transition-colors duration-300 tracking-wide"
					>
						LinkedIn
					</a>
					<a
						href="https://codepen.io/chuydev-exe"
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm font-medium text-gray-400 hover:text-[#51E4B8] transition-colors duration-300 tracking-wide"
					>
						CodePen
					</a>
				</nav>

				<!-- Bottom note -->
				<p class="text-xs text-gray-600 text-center">
					Built with <span class="text-[#51E4B8]">Astro</span> · Deployed on Netlify
				</p>
			</div>
		</footer>
	</body>
</html>
<style>
	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: "Onest Variable", system-ui, sans-serif;
		background-color: #050d15;
		overscroll-behavior: none;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}
</style>
